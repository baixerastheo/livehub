{
  "name": "livehub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter frontend dev\" \"pnpm --filter backend start:dev\"",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend start:dev",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "lint": "pnpm -r lint",
    "review:check": "pnpm --filter frontend lint && pnpm --filter backend lint && pnpm --filter frontend exec tsc --noEmit && pnpm --filter backend exec tsc --noEmit",
    "test": "pnpm -r test",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "db:push": "pnpm --filter backend exec prisma db push",
    "db:generate": "pnpm --filter backend exec prisma generate"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

