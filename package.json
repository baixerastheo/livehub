{
  "name": "livehub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter frontend dev\" \"pnpm --filter backend start:dev\"",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend start:dev",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "lint": "pnpm -r lint",
    "review:check": "pnpm --filter frontend lint && pnpm --filter backend lint && pnpm --filter frontend run typecheck && pnpm --filter backend run typecheck",
    "test": "pnpm -r test",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "db:push": "pnpm --filter backend exec prisma db push",
    "db:generate": "pnpm --filter backend exec prisma generate",
    "dev:electron": "concurrently \"pnpm --filter backend start:dev\" \"pnpm --filter frontend dev\" \"pnpm --filter electron dev\"",
    "build:electron": "pnpm --filter frontend build && pnpm --filter electron build",
    "dist:electron": "pnpm --filter electron dist",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx}": "pnpm --filter frontend lint",
    "backend/src/**/*.ts": "pnpm --filter backend lint"
  }
}
