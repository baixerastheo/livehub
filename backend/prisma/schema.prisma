generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model Utilisateur {
  id              Int          @id @default(autoincrement())
  email           String          @unique
  motDePasse      String
  nomUtilisateur  String         @unique
  statut          StatutUtilisateur @default(EN_LIGNE)
  avatarPath      String?
  avatarUpdatedAt DateTime?
  creeLe          DateTime        @default(now())
  modifieLe       DateTime        @updatedAt
  serveurs        MembreServeur[]
  messages        Message[]
  invitations     Invitation[]
  messagesEnvoyes MessagePrive[] @relation("MessagesEnvoyes")
  messagesRecus   MessagePrive[] @relation("MessagesRecus")
  demandesAmiEnvoyees DemandeAmi[] @relation("DemandesAmiEnvoyees")
  demandesAmiRecues   DemandeAmi[] @relation("DemandesAmiRecues")
  amitiesA Amitie[] @relation("AmitieA")
  amitiesB Amitie[] @relation("AmitieB")

  @@index([email])
  @@index([nomUtilisateur])
  @@map("Utilisateur")
}

enum StatutUtilisateur {
  EN_LIGNE
  ABSENT
  INVISIBLE
  HORS_LIGNE
}

enum StatutDemandeAmi {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
}

model Serveur {
  id          Int        @id @default(autoincrement())
  nom         String
  membres     MembreServeur[]
  canaux      Canal[]
  invitations Invitation[]
  creeLe      DateTime      @default(now())
  modifieLe   DateTime      @updatedAt

  @@index([nom])
}

model MembreServeur {
  id          Int   @id @default(autoincrement())
  serveurId   Int
  serveur     Serveur  @relation(fields: [serveurId], references: [id], onDelete: Cascade)
  utilisateurId Int
  utilisateur Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  role        Role     @default(MEMBRE)
  rejointLe   DateTime @default(now())

  @@unique([utilisateurId, serveurId])
  @@index([serveurId])
  @@index([utilisateurId])
  @@index([serveurId, role])
}

enum Role {
  PROPRIETAIRE
  ADMINISTRATEUR
  MEMBRE
}

model Canal {
  id        Int    @id @default(autoincrement())
  serveurId Int
  serveur   Serveur   @relation(fields: [serveurId], references: [id], onDelete: Cascade)
  nom       String
  messages  Message[]
  creeLe    DateTime  @default(now())
  modifieLe DateTime  @updatedAt

  @@index([serveurId])
}

model Message {
  id         Int   @id @default(autoincrement())
  canalId    Int
  canal      Canal    @relation(fields: [canalId], references: [id], onDelete: Cascade)
  auteurId   Int
  auteur     Utilisateur @relation(fields: [auteurId], references: [id], onDelete: Cascade)
  contenu    String
  creeLe     DateTime @default(now())
  modifieLe  DateTime @updatedAt
  editeLe    DateTime?

  @@index([canalId])
  @@index([canalId, creeLe])
  @@index([auteurId])
}

model Invitation {
  id              String    @id @default(uuid())
  code            String    @unique
  serveurId       Int
  serveur         Serveur   @relation(fields: [serveurId], references: [id], onDelete: Cascade)
  creeParId       Int
  creePar         Utilisateur @relation(fields: [creeParId], references: [id], onDelete: Cascade)
  expireLe        DateTime?
  creeLe          DateTime  @default(now())

  @@index([code])
  @@index([serveurId])
  @@index([creeParId])
}

model MessagePrive {
  id            Int    @id @default(autoincrement())
  expediteurId  Int
  expediteur    Utilisateur @relation("MessagesEnvoyes", fields: [expediteurId], references: [id], onDelete: Cascade)
  destinataireId Int
  destinataire  Utilisateur @relation("MessagesRecus", fields: [destinataireId], references: [id], onDelete: Cascade)
  contenu       String
  lu            Boolean   @default(false)
  creeLe        DateTime  @default(now())
  modifieLe     DateTime  @updatedAt
  editeLe       DateTime?

  @@index([expediteurId, destinataireId])
  @@index([destinataireId])
  @@index([expediteurId])
}

model DemandeAmi {
  id        String @id @default(uuid())
  pairAId   Int
  pairBId   Int
  deId      Int
  de        Utilisateur @relation("DemandesAmiEnvoyees", fields: [deId], references: [id], onDelete: Cascade)
  aId       Int
  a         Utilisateur @relation("DemandesAmiRecues", fields: [aId], references: [id], onDelete: Cascade)
  statut    StatutDemandeAmi @default(EN_ATTENTE)
  creeLe    DateTime @default(now())
  modifieLe DateTime @updatedAt

  @@index([pairAId, pairBId])
  @@index([deId])
  @@index([aId])
  @@index([statut])
  @@unique([pairAId, pairBId])
}

model Amitie {
  id        String @id @default(uuid())
  userAId   Int
  userA     Utilisateur @relation("AmitieA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId   Int
  userB     Utilisateur @relation("AmitieB", fields: [userBId], references: [id], onDelete: Cascade)
  creeLe    DateTime @default(now())

  @@index([userAId])
  @@index([userBId])
  @@unique([userAId, userBId])
}
