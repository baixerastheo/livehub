generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum StatutUtilisateur {
  EN_LIGNE
  ABSENT
  INVISIBLE
  HORS_LIGNE
}

enum Role {
  PROPRIETAIRE
  ADMINISTRATEUR
  MEMBRE
}

model Amitie {
  id        String   @id
  userAId   String
  userBId   String
  userA     User     @relation("Amitie_userAIdToUser", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("Amitie_userBIdToUser", fields: [userBId], references: [id], onDelete: Cascade)
  creeLe    DateTime @default(now())

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

enum StatutDemandeAmitie {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
}

model DemandeAmitie {
  id         String              @id @default(uuid())
  fromUserId String
  toUserId   String
  statut     StatutDemandeAmitie @default(EN_ATTENTE)
  creeLe     DateTime            @default(now())
  fromUser   User                @relation("DemandeAmitie_fromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User                @relation("DemandeAmitie_toUser", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
}



model Serveur {
  id          Int             @id @default(autoincrement())
  nom         String
  membres     MembreServeur[]
  canaux      Canal[]
  invitations Invitation[]
  creeLe      DateTime        @default(now())
  modifieLe   DateTime        @updatedAt

  @@index([nom])
}

model MembreServeur {
  id        Int     @id @default(autoincrement())
  serveurId Int
  serveur   Serveur @relation(fields: [serveurId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role    @default(MEMBRE)
  rejointLe DateTime @default(now())

  @@unique([userId, serveurId])
  @@index([serveurId])
  @@index([userId])
  @@index([serveurId, role])
}


model Canal {
  id        Int       @id @default(autoincrement())
  serveurId Int
  serveur   Serveur   @relation(fields: [serveurId], references: [id], onDelete: Cascade)
  nom       String
  messages  Message[]
  creeLe    DateTime  @default(now())
  modifieLe DateTime  @updatedAt

  @@index([serveurId])
}

model Message {
  id        Int    @id @default(autoincrement())
  canalId   Int
  canal     Canal  @relation(fields: [canalId], references: [id], onDelete: Cascade)
  auteurId  String
  auteur    User   @relation(fields: [auteurId], references: [id], onDelete: Cascade)
  contenu   String
  creeLe    DateTime @default(now())
  modifieLe DateTime @updatedAt
  editeLe   DateTime?

  @@index([canalId])
  @@index([canalId, creeLe])
  @@index([auteurId])
}

model Invitation {
  id        String   @id @default(uuid())
  code      String   @unique
  serveurId Int
  serveur   Serveur  @relation(fields: [serveurId], references: [id], onDelete: Cascade)
  creeParId String
  creePar   User     @relation(fields: [creeParId], references: [id], onDelete: Cascade)
  expireLe  DateTime?
  creeLe    DateTime @default(now())

  @@index([code])
  @@index([serveurId])
  @@index([creeParId])
}

model MessagePrive {
  id             Int      @id @default(autoincrement())
  expediteurId   String
  expediteur     User     @relation("MessagesEnvoyes", fields: [expediteurId], references: [id], onDelete: Cascade)
  destinataireId String
  destinataire   User     @relation("MessagesRecus", fields: [destinataireId], references: [id], onDelete: Cascade)
  contenu        String
  lu             Boolean  @default(false)
  creeLe         DateTime @default(now())
  modifieLe      DateTime @updatedAt
  editeLe        DateTime?

  @@index([expediteurId, destinataireId])
  @@index([destinataireId])
  @@index([expediteurId])
}

model User {
  id               String          @id
  name             String
  email            String
  emailVerified    Boolean         @default(false)
  image            String?
  statut           StatutUtilisateur @default(EN_LIGNE)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  sessions         Session[]
  accounts         Account[]
  membres          MembreServeur[]
  messages         Message[]
  invitations      Invitation[]
  messagesEnvoyes  MessagePrive[]  @relation("MessagesEnvoyes")
  messagesRecus    MessagePrive[]  @relation("MessagesRecus")
  amitiesCommeA       Amitie[]         @relation("Amitie_userAIdToUser")
  amitiesCommeB       Amitie[]         @relation("Amitie_userBIdToUser")
  demandesEnvoyees    DemandeAmitie[]  @relation("DemandeAmitie_fromUser")
  demandesRecues      DemandeAmitie[]  @relation("DemandeAmitie_toUser")

  @@unique([email])
  @@index([name])
  @@index([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
