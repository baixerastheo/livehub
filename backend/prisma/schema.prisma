generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Amitie {
  id      String   @id
  creeLe  DateTime @default(now())
  userAId String
  userBId String
  userA   User     @relation("Amitie_userAIdToUser", fields: [userAId], references: [id], onDelete: Cascade)
  userB   User     @relation("Amitie_userBIdToUser", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model DemandeAmitie {
  id         String              @id @default(uuid())
  fromUserId String
  toUserId   String
  statut     StatutDemandeAmitie @default(EN_ATTENTE)
  creeLe     DateTime            @default(now())
  fromUser   User                @relation("DemandeAmitie_fromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User                @relation("DemandeAmitie_toUser", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
}

model Serveur {
  id          Int             @id @default(autoincrement())
  nom         String
  avatarPath  String?
  creeLe      DateTime        @default(now())
  modifieLe   DateTime        @updatedAt
  membres     MembreServeur[]
  canaux      Canal[]
  invitations Invitation[]
  bans        BanServeur[]

  @@index([nom])
}

model BanServeur {
  id        Int       @id @default(autoincrement())
  serveurId Int
  userId    String
  bannePar  String
  raison    String?
  expireLe  DateTime?
  creeLe    DateTime  @default(now())
  banneur   User      @relation("BansEmis", fields: [bannePar], references: [id], onDelete: Cascade)
  serveur   Serveur   @relation(fields: [serveurId], references: [id], onDelete: Cascade)
  user      User      @relation("BansRecus", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, serveurId])
  @@index([serveurId])
  @@index([userId])
}

model MembreServeur {
  role      Role     @default(MEMBRE)
  rejointLe DateTime @default(now())
  id        Int      @id @default(autoincrement())
  serveurId Int
  userId    String
  serveur   Serveur  @relation(fields: [serveurId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, serveurId])
  @@index([serveurId])
  @@index([userId])
  @@index([serveurId, role])
}

enum TypeCanal {
  TEXTE
  VOCAL
}

model Canal {
  id        Int       @id @default(autoincrement())
  nom       String
  type      TypeCanal @default(TEXTE)
  creeLe    DateTime  @default(now())
  modifieLe DateTime  @updatedAt
  serveurId Int
  serveur   Serveur   @relation(fields: [serveurId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([serveurId])
}

model Message {
  contenu   String
  creeLe    DateTime          @default(now())
  modifieLe DateTime          @updatedAt
  editeLe   DateTime?
  id        Int               @id @default(autoincrement())
  canalId   Int
  auteurId  String
  auteur    User              @relation(fields: [auteurId], references: [id], onDelete: Cascade)
  canal     Canal             @relation(fields: [canalId], references: [id], onDelete: Cascade)
  reactions ReactionMessage[]

  @@index([canalId])
  @@index([canalId, creeLe])
  @@index([auteurId])
}

model ReactionMessage {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    String
  emoji     String
  creeLe    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model Invitation {
  id        String    @id @default(uuid())
  code      String    @unique
  expireLe  DateTime?
  creeLe    DateTime  @default(now())
  serveurId Int
  creeParId String
  creePar   User      @relation(fields: [creeParId], references: [id], onDelete: Cascade)
  serveur   Serveur   @relation(fields: [serveurId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([serveurId])
  @@index([creeParId])
}

model MessagePrive {
  contenu        String
  lu             Boolean                @default(false)
  creeLe         DateTime               @default(now())
  modifieLe      DateTime               @updatedAt
  editeLe        DateTime?
  id             Int                    @id @default(autoincrement())
  expediteurId   String
  destinataireId String
  destinataire   User                   @relation("MessagesRecus", fields: [destinataireId], references: [id], onDelete: Cascade)
  expediteur     User                   @relation("MessagesEnvoyes", fields: [expediteurId], references: [id], onDelete: Cascade)
  reactions      ReactionMessagePrive[]

  @@index([expediteurId, destinataireId])
  @@index([destinataireId])
  @@index([expediteurId])
}

model ReactionMessagePrive {
  id        Int          @id @default(autoincrement())
  messageId Int
  userId    String
  emoji     String
  creeLe    DateTime     @default(now())
  message   MessagePrive @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model User {
  id                    String                 @id
  name                  String
  email                 String                 @unique
  emailVerified         Boolean                @default(false)
  image                 String?
  statut                StatutUtilisateur      @default(EN_LIGNE)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  avatarPath            String?
  avatarUpdatedAt       DateTime?
  amitiesCommeA         Amitie[]               @relation("Amitie_userAIdToUser")
  amitiesCommeB         Amitie[]               @relation("Amitie_userBIdToUser")
  bansEmis              BanServeur[]           @relation("BansEmis")
  bansRecus             BanServeur[]           @relation("BansRecus")
  demandesEnvoyees      DemandeAmitie[]        @relation("DemandeAmitie_fromUser")
  demandesRecues        DemandeAmitie[]        @relation("DemandeAmitie_toUser")
  invitations           Invitation[]
  membres               MembreServeur[]
  messages              Message[]
  messagesRecus         MessagePrive[]         @relation("MessagesRecus")
  messagesEnvoyes       MessagePrive[]         @relation("MessagesEnvoyes")
  reactionsMessage      ReactionMessage[]
  reactionsMessagePrive ReactionMessagePrive[]
  accounts              Account[]
  sessions              Session[]

  @@index([name])
  @@index([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum StatutUtilisateur {
  EN_LIGNE
  ABSENT
  INVISIBLE
  HORS_LIGNE
}

enum Role {
  PROPRIETAIRE
  ADMINISTRATEUR
  MEMBRE
}

enum StatutDemandeAmitie {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
}
