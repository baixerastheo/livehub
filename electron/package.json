{
  "name": "electron",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && cross-env NODE_ENV=development electron .",
    "build": "tsc",
    "dist": "tsc && electron-builder"
  },
  "devDependencies": {
    "@types/node": "^20",
    "cross-env": "^10.1.0",
    "electron": "^36.1.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.livehub.app",
    "productName": "Livehub",
    "icon": "assets/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
